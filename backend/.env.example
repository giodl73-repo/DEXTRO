# Database Configuration
DATABASE_URL=postgresql://apportionment_user:apportionment_pass@localhost:5434/apportionment_db

# CORS Configuration (App Manager dashboard + Frontend)
CORS_ORIGINS=["http://localhost:3002", "http://localhost:9000"]

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info

# Paths
PROJECT_ROOT=.
OUTPUTS_DIR=outputs

# API Configuration
API_VERSION=v1
APP_VERSION=9.0.0

# Pipeline Execution Settings (for Enhancement 62)
DEFAULT_WORKERS=4
WATCHDOG_TIMEOUT=60
PROGRESS_PERSIST_INTERVAL=5
MAX_CONCURRENT_RUNS=1
