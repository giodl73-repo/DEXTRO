%% ===================================================================
%% SPANNING TREES / RANDOM WALK
%% ===================================================================

@article{wilson1996,
  author  = {Wilson, David Bruce},
  title   = {Generating Random Spanning Trees More Quickly than the
             Cover Time},
  journal = {Proceedings of the 28th Annual ACM Symposium on Theory
             of Computing},
  pages   = {296--303},
  year    = {1996},
  doi     = {10.1145/237814.237880},
  note    = {Introduces loop-erased random walk for uniform spanning tree
             (UST) generation.
             The Wilson UST algorithm is the subroutine used in
             Algorithm~\ref{alg:smc} to generate the spanning tree $T$
             of each candidate district component.
             Running time is $O(n \log n)$ for planar graphs.},
}

@article{aldous1991,
  author  = {Aldous, David},
  title   = {The Random Walk Construction of Uniform Spanning Trees
             and Uniform Labelled Trees},
  journal = {SIAM Journal on Discrete Mathematics},
  volume  = {3},
  number  = {4},
  pages   = {450--465},
  year    = {1990},
  doi     = {10.1137/0403039},
  note    = {Establishes that the loop-erased random walk produces a
             uniformly random spanning tree.
             This uniformity is critical for the importance-weight
             derivation in Proposition~\ref{prop:weight-correct}:
             each spanning tree $T$ is drawn with probability
             $1/|\mathrm{UST}(C)|$, so the proposal probability of
             a given cut edge $e^*$ is $1/|T|$ times
             $1/|\mathrm{valid\_cuts}(T)|$.},
}

