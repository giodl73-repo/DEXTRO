%% B.21 --- Adaptive Multi-scale MCMC
%% References

%% ===================================================================
%% CORE: ROBBINS-MONRO AND ADAPTIVE MCMC
%% ===================================================================

@article{robbins1951,
  author  = {Robbins, Herbert and Monro, Sutton},
  title   = {A Stochastic Approximation Method},
  journal = {Annals of Mathematical Statistics},
  volume  = {22},
  number  = {3},
  pages   = {400--407},
  year    = {1951},
  doi     = {10.1214/aoms/1177729586},
  note    = {Foundational paper introducing stochastic approximation.
             Proves convergence of the iterate $\alpha_{t+1} = \alpha_t -
             \gamma_t (h(\alpha_t) + \varepsilon_t)$ to the root of $h$
             under step-size conditions $\sum \gamma_t = \infty$,
             $\sum \gamma_t^2 < \infty$, and monotonicity of $h$.
             Provides the theoretical foundation for the \ams{} adaptation
             loop in B.21.},
}

@article{haario2001,
  author  = {Haario, Heikki and Saksman, Eero and Tamminen, Johanna},
  title   = {An Adaptive {Metropolis} Algorithm},
  journal = {Bernoulli},
  volume  = {7},
  number  = {2},
  pages   = {223--242},
  year    = {2001},
  doi     = {10.2307/3318737},
  note    = {Introduces the Adaptive Metropolis (AM) algorithm, which
             updates the covariance of a Gaussian proposal kernel online
             using the empirical covariance of accepted samples.
             Proves ergodicity under diminishing adaptation.
             Related to \ams{}: both adapt MCMC kernels online, but AM
             adapts a proposal covariance while \ams{} adapts a mixing
             ratio between two fixed kernels.},
}

@article{andrieu2008,
  author  = {Andrieu, Christophe and Thoms, Johannes},
  title   = {A Tutorial on Adaptive {MCMC}},
  journal = {Statistics and Computing},
  volume  = {18},
  number  = {4},
  pages   = {343--373},
  year    = {2008},
  doi     = {10.1007/s11222-008-9110-y},
  note    = {Tutorial on adaptive MCMC theory, covering the diminishing
             adaptation and containment conditions for ergodicity of
             adaptive chains.
             B.21 appeals to diminishing adaptation (Robbins-Monro step
             decay) and containment (alpha clip) as the two key conditions
             ensuring the adapted chain converges.},
}

