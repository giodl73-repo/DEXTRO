@article{deford2021,
  author  = {DeFord, Daryl and Duchin, Moon and Solomon, Justin},
  title   = {Recombination: A Family of {Markov} Chains for Redistricting},
  journal = {Harvard Data Science Review},
  volume  = {3},
  number  = {1},
  year    = {2021},
  doi     = {10.1162/99608f92.eb30390f},
  note    = {ReCom Markov chain redistricting sampler.
             The fine-level kernel used inside \ms{} and \ams{}.
             \recom{} proposes changes by merging two adjacent districts
             and re-splitting via a spanning tree.
             B.21 Table~1 uses single-scale \recom{} as the baseline
             against which multi-scale mixing improvements are measured.},
}

