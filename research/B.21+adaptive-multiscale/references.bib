@misc{dellaLibera2026multiscale,
  author = {Della-Libera, Gio},
  title  = {Multi-scale {MCMC} for Redistricting: Coarse-Level Mixing
            via County Aggregation},
  year   = {2026},
  note   = {G.11 in Algorithmic Redistricting series.
            Introduces \ms{} (MultiScale MCMC), the parent algorithm
            extended by \ams{}.
            Defines the MSC\_STEP\_ seeding formula, the coarse-level
            HierarchyLevel structure, and the 200-iteration rebalancer.
            All of these are inherited unchanged by \ams{}.},
}

@article{autry2021,
  author  = {Autry, Eric and Carter, Daniel and Herschlag, Gregory
             and Hunter, Zach and Mattingly, Jonathan Christopher},
  title   = {Metropolized Multiscale Forest Recombination for
             Redistricting},
  journal = {Multiscale Modeling and Simulation},
  volume  = {19},
  number  = {4},
  pages   = {1885--1914},
  year    = {2021},
  doi     = {10.1137/21M1406854},
  note    = {Introduces multi-scale mixing for redistricting Markov chains
             via forest recombination.
             Demonstrates that coarse-level proposals improve mixing
             compared to single-scale \recom{}.
             Does not address the alpha-tuning problem (the mixing ratio
             between coarse and fine proposals is fixed).
             B.21 closes this gap using Robbins-Monro adaptation.},
}

