%% LEGAL CASES
%% ===================================================================

@misc{callais2026,
  title  = {Louisiana v.\ {Callais}},
  year   = {2026},
  note   = {608 U.S.\ \_\_\_ (2026).
            Holdings: (1) extra minority district was unconstitutional racial
            gerrymandering; (2) strong-inference framework for \S2 challengers;
            (3) p.36: race-conscious and partisan signals must be disentangled.
            Architecturally decisive for algorithmic redistricting design.},
}

@misc{wesberry1964,
  title  = {Wesberry v.\ Sanders},
  year   = {1964},
  note   = {376 U.S. 1 (1964). One person, one vote; congressional districts
            must have equal population ``as nearly as is practicable.''
            Foundational premise of all federal redistricting law.},
}

@misc{karcher1983,
  title  = {Karcher v.\ Daggett},
  year   = {1983},
  note   = {462 U.S. 725 (1983). Any population deviation in congressional
            districts must be justified; effectively zero tolerance standard.
            Operationalizes Wesberry into a near-absolute requirement.},
}

@misc{montana1992,
  title  = {United States Department of Commerce v.\ Montana},
  year   = {1992},
  note   = {503 U.S. 442 (1992). Upheld Huntington-Hill (equal proportions)
            as a rational congressional choice for the apportionment method.
            Confirmed Article~I authority over apportionment methodology.},
}

@misc{rucho2019,
  title  = {Rucho v.\ Common Cause},
  year   = {2019},
  note   = {588 U.S. 684 (2019). Partisan gerrymandering presents political
            questions beyond federal court reach; state courts retain
            jurisdiction. Creates legislative opening for the DIA.},
}

@misc{allenmilligan2023,
  title  = {Allen v.\ Milligan},
  year   = {2023},
  note   = {598 U.S. 1 (2023). Alabama required to draw two Black-opportunity
            districts; reaffirmed and clarified Gingles three-prong test.
            VRASection produces the required two-district result empirically.},
}

@misc{gingles1986,
  title  = {Thornburg v.\ Gingles},
  year   = {1986},
  note   = {478 U.S. 30 (1986). Three-prong test for VRA \S2:
            (1) minority group sufficiently large and geographically compact,
            (2) minority cohesion, (3) majority bloc voting.
            DIA VRA overlay triggered only when all three prongs are met.},
}

@misc{shaw1993,
  title  = {Shaw v.\ Reno},
  year   = {1993},
  note   = {509 U.S. 630 (1993). Districts with ``bizarre'' shapes suggesting
            racial predominance trigger strict scrutiny. ApportionRegions
            default run contains zero racial input; Shaw is moot.},
}

@misc{miller1995,
  title  = {Miller v.\ Johnson},
  year   = {1995},
  note   = {515 U.S. 900 (1995). Race cannot be the ``predominant factor''
            overriding traditional districting principles.
            VRASection $w_\text{vra}=0.40$ calibrated below this threshold.},
}

@misc{bushvvera1996,
  title  = {Bush v.\ Vera},
  year   = {1996},
  note   = {517 U.S. 952 (1996). Applied Miller racial-predominance test;
            ``race was not the predominant factor overriding traditional
            districting principles'' is the operative standard.
            VRASection satisfies this because compactness dominates at $w=0.40$.},
}

@misc{lwvpa2018,
  title  = {League of Women Voters v.\ Commonwealth of Pennsylvania},
  year   = {2018},
  note   = {Pa. Supreme Court No.\ 159 MM 2017. Pennsylvania's congressional
            map struck down as partisan gerrymander under Pennsylvania Constitution.
            Demonstrates post-Rucho state-court litigation burden the DIA eliminates.},
}

@misc{harper2022,
  title  = {Harper v.\ Hall},
  year   = {2022},
  note   = {N.C. Supreme Court, 2022 (initial decision).
            Found unconstitutional partisan gerrymander; required county grouping
            compliance. Demonstrates state-court redistricting litigation costs
            the DIA avoids.},
}

@misc{harkenrider2022,
  title  = {Harkenrider v.\ Hochul},
  year   = {2022},
  note   = {N.Y. Court of Appeals, 2022.
            Struck down Democratic partisan gerrymander under New York Constitution.
            Demonstrates bipartisan nature of gerrymandering abuse.},
}

@misc{benilek2019,
  title  = {Benisek v.\ Lamone},
  year   = {2019},
  note   = {585 U.S. 155 (2019). Maryland congressional map challenged as
            ``drastic partisan gerrymander'' by Republican plaintiffs.
            Consolidated with Rucho; illustrates bipartisan gerrymandering.},
}

@misc{smiley1932,
  title  = {Smiley v.\ {Holm}},
  year   = {1932},
  note   = {285 U.S. 355 (1932). Congress has plenary authority under the
            Elections Clause to regulate congressional elections, including
            redistricting. Article~I, \S4 authority for the DIA.},
}

@misc{arizonalegislature2015,
  title  = {Arizona State Legislature v.\ Arizona Independent Redistricting Commission},
  year   = {2015},
  note   = {576 U.S. 787 (2015). Elections Clause covers redistricting;
            affirmed federal authority over congressional district lines.
            Confirms constitutional basis for the DIA.},
}

@misc{stephenson2002,
  title  = {Stephenson v.\ Bartlett},
  year   = {2002},
  note   = {N.C. Supreme Court, 355 N.C. 354 (2002).
            County-grouping requirement established for North Carolina
            redistricting. Precedent for county preservation as a legitimate
            redistricting criterion.},
}

@misc{vra1965,
  title  = {Voting Rights Act of 1965},
  year   = {1965},
  note   = {52 U.S.C.\ \S10301 (formerly 42 U.S.C.\ \S1973).
            Section 2 prohibits voting practices that dilute minority voting
            strength. DIA VRA overlay implements \S2 compliance algorithmically.},
}

@misc{huntingtonhill1941,
  title  = {Apportionment Act of 1941},
  year   = {1941},
  note   = {2 U.S.C.\ \S2a(a). Codifies the method of equal proportions
            (Huntington-Hill) as the statutory method for apportioning
            congressional seats among states. The DIA proposes to extend this
            method intrastate as 2 U.S.C.\ \S2a(c) [new].},
}

