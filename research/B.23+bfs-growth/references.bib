@article{kernighan1970,
  author  = {Kernighan, Brian W. and Lin, Shen},
  title   = {An Efficient Heuristic Procedure for Partitioning Graphs},
  journal = {Bell System Technical Journal},
  volume  = {49},
  number  = {2},
  pages   = {291--307},
  year    = {1970},
  doi     = {10.1002/j.1538-7305.1970.tb01770.x},
  note    = {Original KL partitioning algorithm. Terminates at a local optimum
             defined by single-vertex boundary swaps. BFS Growth has no
             such local-optimum refinement phase; it makes exactly one greedy
             pass and applies boundary-swap rebalance only for population
             feasibility, not edge-cut minimisation.},
}

@book{cormen2009,
