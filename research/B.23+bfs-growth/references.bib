@article{du1999,
  author  = {Du, Qiang and Faber, Vance and Gunzburger, Max},
  title   = {Centroidal {Voronoi} Tessellations: Applications and Algorithms},
  journal = {SIAM Review},
  volume  = {41},
  number  = {4},
  pages   = {637--676},
  year    = {1999},
  doi     = {10.1137/S0036144599352836},
  note    = {Foundational CVD paper. Iterative Lloyd's algorithm alternates
             Voronoi assignment (geographic proximity) and centroid update.
             BFS Growth is the non-iterative analogue: a single BFS pass
             with population-deficit priority replaces Lloyd's iterations.
             CVD converges to a lower-distortion solution at higher
             computational cost.},
}

@article{lloyd1982,
  author  = {Lloyd, Stuart P.},
  title   = {Least Squares Quantization in {PCM}},
  journal = {IEEE Transactions on Information Theory},
  volume  = {28},
  number  = {2},
  pages   = {129--137},
  year    = {1982},
  doi     = {10.1109/TIT.1982.1056489},
  note    = {Lloyd's algorithm: the k-means iteration underlying CVD.
             Each CVD round is one Lloyd iteration applied to geographic
             distance in the adjacency graph. BFS Growth makes zero Lloyd
             iterations.},
}

