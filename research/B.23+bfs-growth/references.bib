  journal = {Midwest Journal of Political Science},
  volume  = {5},
  number  = {1},
  pages   = {70--74},
  year    = {1961},
  note    = {Reock compactness ratio: ratio of district area to area of
             minimum bounding circle. Secondary compactness metric reported
             in B.23 Table~1 alongside Polsby-Popper. Reock penalises
             elongated districts; BFS Growth's geographic proximity tends
             to produce more convex districts than optimisation-based methods
             on regular grids but less so on irregular geography.},
}

