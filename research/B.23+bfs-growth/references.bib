  title     = {Introduction to Algorithms},
  edition   = {3rd},
  publisher = {MIT Press},
  year      = {2009},
  note      = {Standard reference for BFS ($O(V + E)$ time) and binary heap
               priority queues ($O(\log n)$ per operation). The $O(n \log n)$
               complexity of BFS Growth follows from $n$ priority-queue
               operations during the growth phase.},
}

