@inproceedings{gurnee2021,
  author    = {Gurnee, Wes and Shmoys, David B.},
  title     = {Fairmandering: A Column Generation Heuristic for
               Fairness-Optimized Political Districting},
  booktitle = {Proceedings of the AAAI Workshop on AI for Social Good},
  year      = {2021},
  note      = {Introduces Fairmandering: column-generation heuristic for
               fairness-optimised redistricting. Section~2 surveys ILP
               redistricting formulations and identifies the both-endpoint
               MTZ bound as the most effective contiguity constraint for
               instances with $n \leq 500$ tracts. Reports solve times
               of 30--120\,s for $k=2$, $n=250$ on a 2019 laptop with
               Gurobi, consistent with B.24 empirical results using GLPK.},
}

