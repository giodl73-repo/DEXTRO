%% ILP FORMULATION THEORY
%% ===================================================================

@book{nemhauser1988,
  author    = {Nemhauser, George L. and Wolsey, Laurence A.},
  title     = {Integer and Combinatorial Optimization},
  publisher = {Wiley},
  year      = {1988},
  note      = {Standard reference for ILP theory: branch-and-bound,
               LP relaxation bounds, and optimality certificates.
               Chapter~1 establishes that the feasible region is the
               convex hull of integer points and that branch-and-bound
               with LP bounds provides finite-termination exact
               optimisation. DFJ subtour-elimination cuts discussed
               in Chapter~8.},
}

@article{mtz1960,
  author  = {Miller, Clair E. and Tucker, Albert W. and Zemlin, Richard A.},
  title   = {Integer Programming Formulation of Traveling Salesman Problems},
  journal = {Journal of the ACM},
  volume  = {7},
  number  = {4},
  pages   = {326--329},
  year    = {1960},
  doi     = {10.1145/321043.321046},
  note    = {Original MTZ paper: flow-based contiguity constraints for TSP.
             Adapted for redistricting contiguity in B.24: each district $d$
             has a designated root; flow from root enforces a spanning tree
             over $d$'s tracts. The both-endpoint capacity bound tightens
             the standard MTZ formulation for redistricting instances.},
}

