@article{swendsen1986,
  author  = {Swendsen, Robert H. and Wang, Jian-Sheng},
  title   = {Replica {Monte Carlo} Simulation of Spin-Glasses},
  journal = {Physical Review Letters},
  volume  = {57},
  number  = {21},
  pages   = {2607--2609},
  year    = {1986},
  doi     = {10.1103/PhysRevLett.57.2607},
  note    = {Foundational parallel tempering paper. Introduces simultaneous
             simulation at multiple temperatures with periodic replica-exchange
             proposals accepted via the Metropolis criterion. B.20's
             implementation of \textsc{ParallelTempering} follows the
             Swendsen-Wang architecture with balance tolerance as the
             effective temperature parameter.},
}

@inproceedings{geyer1991,
  author    = {Geyer, Charles J.},
  title     = {Markov Chain {Monte Carlo} Maximum Likelihood},
  booktitle = {Computing Science and Statistics: Proceedings of the 23rd
               Symposium on the Interface},
  editor    = {Keramidas, E. M.},
  pages     = {156--163},
  year      = {1991},
  note      = {Introduces simulated tempering and provides the first
               theoretical analysis of parallel tempering convergence.
               Establishes that the stationary distribution of the cold
               chain is the target distribution at the cold temperature,
               which justifies using the cold chain output for plan
               selection in B.20.},
}

@article{kone2005,
  author  = {Kone, Amadou and Kofke, David A.},
  title   = {Selection of Temperature Intervals for Parallel-Tempering Simulations},
  journal = {Journal of Chemical Physics},
  volume  = {122},
  number  = {10},
  pages   = {104114},
  year    = {2005},
  doi     = {10.1063/1.1860556},
  note    = {Source of the ${\approx}23\%$ empirical swap acceptance target
             for geometric temperature ladders. Derived for continuous
             Gaussian systems; B.20 adopts this as an empirical starting
             point for discrete redistricting chains, not a theoretical
             guarantee. The observed $18$--$24\%$ swap acceptance rates in
             B.20's experiments are consistent with this target.},
}

@article{earl2005,
  author  = {Earl, David J. and Deem, Michael W.},
  title   = {Parallel Tempering: Theory, Applications, and New Perspectives},
  journal = {Physical Chemistry Chemical Physics},
  volume  = {7},
  number  = {23},
  pages   = {3910--3916},
  year    = {2005},
  doi     = {10.1039/b509983h},
  note    = {Review of parallel tempering theory and best practices.
             Covers geometric ladder design, swap acceptance optimality,
             and the relationship between the number of replicas and
             mixing time. B.20's four-replica default and swap interval
             choice follow the practical guidance in this review.},
}

