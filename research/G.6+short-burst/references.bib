@article{cannon2022,
  author  = {Cannon, Sarah and Duchin, Moon and Randall, Dana and Rule, Parker},
  title   = {Voting Rights, {Markov} Chains, and Optimization},
  journal = {arXiv},
  year    = {2022},
  note    = {arXiv:2207.07690. Introduces Short-Burst optimization for
