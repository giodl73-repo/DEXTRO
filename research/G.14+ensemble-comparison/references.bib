@misc{dellaLibera2026shortburst,
  author = {Della-Libera, Gio},
  title  = {Short-{B}urst {MCMC}: Compactness Optimisation via Repeated
            Exploration Bursts},
  year   = {2026},
  note   = {G.6 in Algorithmic Redistricting series.
            Implements Short-Burst ReCom with burst length and restart
            schedule. The primary compactness optimisation algorithm in
            the redist platform. Achieves lowest EC in all comparisons.},
}

@misc{dellaLibera2026smc,
  author = {Della-Libera, Gio},
  title  = {Sequential {M}onte {C}arlo for Redistricting: Calibrated
            Plan Sampling},
  year   = {2026},
  note   = {G.7 in Algorithmic Redistricting series.
            Implements SMC with importance-weighted particles for exact
            target distribution. The only algorithm with a calibrated,
            mathematically specified target distribution. Recommended for
            litigation-quality ensembles.},
}

@misc{dellaLibera2026flip,
  author = {Della-Libera, Gio},
  title  = {Flip {MCMC}: Boundary-Tract Sensitivity Analysis for
            Redistricting},
  year   = {2026},
  note   = {G.8 in Algorithmic Redistricting series.
            Implements single-tract boundary flip Markov chain for local
            sensitivity analysis. High autocorrelation is intentional:
            the chain explores the local neighbourhood of the initial plan
            to characterise fragile boundary tracts.},
}

@misc{dellaLibera2026forestRecom,
  author = {Della-Libera, Gio},
  title  = {Forest {ReCom}: Reversible Recombination via Spanning Forest
            Sampling},
  year   = {2026},
  note   = {G.9 in Algorithmic Redistricting series.
            Implements ForestReCom with Metropolis-Hastings ratio for
            distributional correctness. Provides approximately uniform
            distribution over valid plans; baseline for approximately
            uniform chain comparisons.},
}

@misc{dellaLibera2026mergeSplit,
  author = {Della-Libera, Gio},
  title  = {Merge-{S}plit {MCMC}: Balanced Recombination for
            Redistricting},
  year   = {2026},
  note   = {G.10 in Algorithmic Redistricting series.
            Merge-Split chain with approximately uniform target
            distribution. Recommended as the general-purpose algorithm
            for small-k redistricting without special requirements.
            Marginally lower autocorrelation than Forest ReCom.},
}

@misc{dellaLibera2026multiscale,
  author = {Della-Libera, Gio},
  title  = {Multi-scale {MCMC}: Hierarchical Mixing for Large-$k$
            Redistricting},
  year   = {2026},
  note   = {G.11 in Algorithmic Redistricting series.
            Implements Multi-scale MCMC Option B (tract-county) using
            GEOID prefix coarsening. Recommended for states with
            k >= 20; reduces lag-100 autocorrelation by 27--43\%
            relative to single-scale chains.},
}

@misc{dellaLibera2026shortburstChains,
  author = {Della-Libera, Gio},
  title  = {{ShortBurstForest}: Compactness Optimisation on
            Forest {ReCom} Chains},
  year   = {2026},
  note   = {G.12 in Algorithmic Redistricting series.
            Runs Short-Burst optimisation strategy on the ForestReCom
            chain rather than standard ReCom, combining compactness
            optimisation with MH-corrected distributional properties.
            Second-lowest EC; recommended when distributional awareness
            is required alongside compactness.},
}

@misc{dellaLibera2026vraAware,
  author = {Della-Libera, Gio},
  title  = {{VRA}-Aware {ReCom}: Minority-Majority District Preservation
            via Adaptive Sampling},
  year   = {2026},
  note   = {G.13 in Algorithmic Redistricting series.
            VRA-constrained ReCom chain with adaptive boosts to maintain
            minority-majority districts throughout sampling. The only
            algorithm that enforces VRA constraints during chain execution
            (not merely post hoc). Required for VRA Section 2 analysis.},
}

