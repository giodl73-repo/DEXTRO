@misc{b2paper,
  author = {Della-Libera, Gio},
  title  = {Edge-Weighted Bisection for Compact Congressional Districts:
            Geographic Boundary Lengths as Compactness Signal},
  year   = {2026},
  note   = {B.2 in Algorithmic Redistricting series.
            Key result: $+56\,\%$ Polsby-Popper improvement over unweighted.
            Geographic boundary-length edge weights used as the default
            configuration in the empirical experiments of B.19.},
}

@misc{b6paper,
  author = {Della-Libera, Gio},
  title  = {Computational Complexity of Minimum-Edge-Cut Congressional
            Redistricting},
  year   = {2026},
  note   = {B.6 in Algorithmic Redistricting series.
            Establishes $\mathcal{NP}$-hardness of graph minimum bisection
            in the redistricting context. Provides the complexity-theoretic
            motivation for heuristic solvers such as \textsc{Metis} and SA.},
}

@misc{b7paper,
  author = {Della-Libera, Gio},
  title  = {The Solution Space of Minimum-Edge-Cut Redistricting:
            Seed Sensitivity and Partisan Variance},
  year   = {2026},
  note   = {B.7 in Algorithmic Redistricting series.
            50-state 1{,}500-seed sweep. Provides the seed-sensitivity
            baseline and the partisan-outcome variance data used throughout
            B.19. Statewide swing model used for D/R seat projections.},
}

@misc{b8paper,
  author = {Della-Libera, Gio},
  title  = {{GeoSection}: Isoperimetrically-Normalised Ratio-Optimal Bisection
            for Congressional Redistricting},
  year   = {2026},
  note   = {B.8 in Algorithmic Redistricting series.
            Introduces the \textsc{GeoSection} structure-layer algorithm
            and the normalised edge-cut metric
            $\mathrm{EC}_\text{norm} = \mathrm{EC}/\sqrt{\min(i,k-i)}$.
            Empirical PP baselines (NC 0.217, WI 0.198, TX 0.184) used
            as the METIS-only baseline in B.19 Table 1.},
}

@misc{b9paper,
  author = {Della-Libera, Gio},
  title  = {{AreaSection}: Geographic Area-Swing Bisection for
            Compact Congressional Districts},
  year   = {2026},
  note   = {B.9 in Algorithmic Redistricting series.
            Introduces \textsc{AreaSection} as a structure-layer variant
            that adds area-swing constraints. Related to B.19 as a
            concurrent approach to improving per-node bisection quality
            via objective modification (vs.\ SA's solver modification).},
}

@misc{b11paper,
  author = {Della-Libera, Gio},
  title  = {{ApportionRegions}: Prime-Factorisation Bisection Trees
            Linked to {Huntington-Hill} Apportionment},
  year   = {2026},
  note   = {B.11 in Algorithmic Redistricting series.
            Key result: zero seed variance --- bisection tree structure
            is determined by the prime factorisation of $k$.
            SA bisection can compose with the ApportionRegions tree
            structure; this is identified as future work in B.19.},
}

@misc{b16paper,
  author = {Della-Libera, Gio},
  title  = {{ConvergenceSweep}: $T = 600$ as the Statutory Stopping
            Criterion for Minimum-Edge-Cut Redistricting},
  year   = {2026},
  note   = {B.16 in Algorithmic Redistricting series.
            Introduces \textsc{ConvergenceSweep} as the SeedCompositor
            strategy. SA bisection is orthogonal to ConvergenceSweep:
            each CS seed can use an SA bisector. B.19 Table 1 uses CS
            as the multi-seed quality upper bound.},
}

@misc{h1paper,
  author = {Della-Libera, Gio},
  title  = {{BisectionEnsemble}: Parallel Seed Search for
            Minimum-Edge-Cut Redistricting},
  year   = {2026},
  note   = {H.1 in Algorithmic Redistricting series.
            Introduces \textsc{BisectionEnsemble} with $T$ parallel seeds.
            H.1 provides the 50-state PP baselines (NC 0.217, WI 0.198,
            TX 0.184) and the BE($T=100$) quality benchmark used in
            B.19 Table 1. SA bisection is positioned between single-seed
            METIS and BE($T=100$).},
}

