%% B.22 --- Centroidal Voronoi Districts
%% References

%% ===================================================================
%% CENTROIDAL VORONOI TESSELLATIONS
%% ===================================================================

@article{lloyd1982,
  author  = {Lloyd, Stuart P.},
  title   = {Least Squares Quantization in {PCM}},
  journal = {IEEE Transactions on Information Theory},
  volume  = {28},
  number  = {2},
  pages   = {129--137},
  year    = {1982},
  doi     = {10.1109/TIT.1982.1056489},
  note    = {Foundational paper on optimal quantisation via iterative
             centroid update. Introduces what is now called Lloyd's
             algorithm: assign each point to its nearest centre, move
             each centre to the centroid of its cluster, repeat.
             B.22 adapts this to discrete weighted graphs via the
             graph-distance medoid as the centroid surrogate.},
}

@article{du1999,
  author  = {Du, Qiang and Faber, Vance and Gunzburger, Max},
  title   = {Centroidal {Voronoi} Tessellations: Applications and Algorithms},
  journal = {SIAM Review},
  volume  = {41},
  number  = {4},
  pages   = {637--676},
  year    = {1999},
  doi     = {10.1137/S0036144599352836},
  note    = {Comprehensive analysis of CVTs: existence, uniqueness,
             convergence, and applications. Proves convergence of
             Lloyd's algorithm under mild regularity conditions.
             B.22 inherits the convergence intuition for the discrete
             graph-distance setting; formal convergence proof for
             non-Euclidean medoid update is identified as future work.},
}

%% ===================================================================
%% K-MEDOIDS CLUSTERING
%% ===================================================================

@article{park2009,
  author  = {Park, Hae-Sang and Jun, Chi-Hyuck},
  title   = {A Simple and Fast Algorithm for {K}-Medoids Clustering},
  journal = {Expert Systems with Applications},
  volume  = {36},
  number  = {2},
  pages   = {3336--3341},
  year    = {2009},
  doi     = {10.1016/j.eswa.2008.01.039},
  note    = {Efficient k-medoids algorithm. Medoid is the actual data
             point minimising mean distance to all others in the cluster,
             unlike the k-means centroid (which may not be a real point).
             B.22 uses the graph-distance medoid for exactly this reason:
             discrete tract graphs require a real tract as the seed,
             not a fractional average location.},
}

