@article{deford2021,
  author  = {DeFord, Daryl and Duchin, Moon and Solomon, Justin},
  title   = {Recombination: A Family of {Markov} Chains for Redistricting},
  journal = {Harvard Data Science Review},
  volume  = {3},
  number  = {1},
  year    = {2021},
  doi     = {10.1162/99608f92.eb30390f},
  note    = {Standard ReCom proposal. Merges two adjacent districts,
             samples a random spanning tree of the merged region, and
             accepts the first balanced cut. Acceptance ratio is
             implicitly 1 (both forward and reverse have the same
             structure under the uniform spanning tree measure), so the
             stationary distribution is unknown.
             Section~\ref{sec:background} explains why this symmetry
             holds and why Merge-Split breaks it.},
}

