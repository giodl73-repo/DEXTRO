@misc{janson2022,
  author = {Janson, Svante},
  title  = {Randomly Chosen Spanning Trees in Practice: Redistricting and
            the {Merge-Split} {Markov} Chain},
  year   = {2022},
  note   = {Introduces the Merge-Split MCMC proposal for redistricting.
            Algorithm: sample independent spanning trees $T_{\mathrm{fwd}}$
            and $T_{\mathrm{rev}}$ of the merged region; accept with
            probability $\min(1, \mathrm{cuts\_fwd}/\mathrm{cuts\_rev})$.
            Shows approximate targeting of the uniform distribution.
            This paper (G.10) implements Janson's algorithm in Rust and
            provides empirical acceptance rates and EC quality for US
            congressional districts.},
}

%% ===================================================================
%% FOREST RECOM / MCCARTAN
%% ===================================================================

@article{mccartan2020,
  author  = {McCartan, Cory and Imai, Kosuke},
  title   = {Sequential {Monte} {Carlo} for Sampling Balanced and Compact
             Redistricting Plans},
  journal = {arXiv},
  year    = {2020},
  note    = {arXiv:2008.06131. Introduces Forest ReCom (referred to in
             subsequent literature as the spanning-forest proposal).
             Acceptance ratio uses the ratio of spanning forest counts
             (matrix-tree determinants), giving exact targeting of the
             uniform distribution over forests. Per-step cost $O(m^2)$.
             Merge-Split replaces the determinant with a random estimate
             from an independent spanning tree, reducing cost to
             $O(m \log m)$.},
}

